{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.fgasparetto/invoicetronic-mcp",
  "title": "Invoicetronic MCP Server",
  "description": "MCP server for Italian electronic invoicing (SDI) via Invoicetronic API",
  "version": "1.0.1",
  "repository": {
    "url": "https://github.com/fgasparetto/invoicetronic-mcp",
    "source": "github"
  },
  "packages": [{
    "registryType": "pypi",
    "identifier": "invoicetronic-mcp",
    "version": "1.0.1",
    "transport": { "type": "stdio" },
    "environmentVariables": [
      {
        "name": "INVOICETRONIC_API_KEY",
        "description": "Invoicetronic API key",
        "isRequired": true,
        "isSecret": true
      }
    ]
  }]
}
